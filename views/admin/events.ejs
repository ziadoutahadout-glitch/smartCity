<div class="at">Événements</div>
<div class="as">Gérer les événements du site</div>
<div class="fc">
  <form method="POST" action="/admin/events/add" enctype="multipart/form-data">
    <h3>Ajouter un événement</h3>
    <div class="fr">
      <div class="fg"><label>Titre</label><input type="text" name="title" placeholder="Titre" required></div>
      <div class="fg"><label>Date Complète (ex: 15 Octobre 2024)</label><input type="text" name="event_date"
          placeholder="15 Octobre 2024"></div>
    </div>
    <div class="fr">
      <div class="fg"><label>Jour (ex: 15)</label><input type="text" name="day" placeholder="15"></div>
      <div class="fg"><label>Mois (ex: Oct)</label><input type="text" name="month" placeholder="Oct"></div>
    </div>
    <div class="fr">
      <div class="fg"><label>Heure</label><input type="text" name="time" placeholder="09:00 - 12:00"></div>
      <div class="fg"><label>Lieu</label><input type="text" name="location" placeholder="Centre Smart City"></div>
    </div>
    <div class="fg"><label>Description</label><textarea name="description" placeholder="Description..."></textarea></div>
    <div class="fr">
      <div class="fg">
        <label>Type</label>
        <select name="type">
          <option value="Conférence">Conférence</option>
          <option value="Atelier">Atelier</option>
          <option value="Séminaire">Séminaire</option>
        </select>
      </div>
      <div class="fg"><label>Image de l'événement</label><input type="file" name="image_file" accept="image/*"></div>
    </div>
    <div class="fg"><label>URL externe (facultatif)</label><input type="text" name="url" placeholder="https://..."></div>
    <button type="submit" class="btn-p">Enregistrer</button>
  </form>
</div>
<div class="a-table">
  <div class="ath">
    <h3>Événements existants</h3>
  </div>
  <table>
    <tr>
      <th>Titre</th>
      <th>Date</th>
      <th>Type</th>
      <th>Actions</th>
    </tr>
    <% events.forEach(ev=> { %>
      <tr>
        <td>
          <%= ev.title %>
        </td>
        <td>
          <%= ev.day %>
            <%= ev.month %>
        </td>
        <td><span class="tag" style="font-size:10px">
            <%= ev.type %>
          </span></td>
        <td>
          <div style="display:flex;gap:5px">
            <button class="ab abe" title="Modifier (Bientôt disponible)">✏</button>
            <form method="POST" action="/admin/events/delete/<%= ev.id %>"
              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement cet événement ?');"
              style="margin:0">
              <button type="submit" class="ab abd" title="Supprimer">✕</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
  </table>
</div>