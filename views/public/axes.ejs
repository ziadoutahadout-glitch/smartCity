<div class="ph"><div class="ph-in"><div class="hbadge">Expertise</div><h1 style="font-size:clamp(24px,3vw,42px);font-weight:700;color:white;margin-top:12px">Axes de Recherche</h1></div></div>
<style>
  .axe-desc ul { padding-left: 1.5rem; margin-top: 10px; margin-bottom: 15px; color: var(--gy); list-style-type: disc; font-size: 14.5px; }
  .axe-desc li { margin-bottom: 8px; line-height: 1.7; }
</style>
<div style="padding:60px 1.5rem;min-height:calc(100vh - 200px);background:var(--cr)"><div style="max-width:1200px;margin:0 auto">
  <% if (axes && axes.length > 0) { %>
    <% axes.forEach((axe, index) => { %>
      <div class="axe-row rv">
        <div class="axe-rl <%= index % 2 === 0 ? 'odd' : 'even' %>">
          <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
          <h2><%= axe.ordre === 10 ? 'Transversal' : 'Axe ' + axe.ordre %></h2>
          <h3><%= axe.nom_fr %></h3>
        </div>
        <div class="axe-rr">
          <div class="axe-desc"><%- axe.description || '<p>Domaine de recherche clé du centre.</p>' %></div>
          <a href="/projets" class="btn-s" style="margin-top:16px">Projets liés</a>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p style="text-align:center; color:white;">Les axes de recherche sont en cours de mise à jour.</p>
  <% } %>
</div></div>
